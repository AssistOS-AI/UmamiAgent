{
  "container": "postgres:16-alpine",
  "start": "postgres",
  "readiness": {
    "protocol": "tcp"
  },
  "network": {
    "name": "analytics",
    "aliases": ["analytics-db"]
  },
  "about": "PostgreSQL database for the self-hosted Umami analytics stack.",
  "endpoints": {
    "agent-card": {
      "name": "Analytics DB",
      "description": "Runs the PostgreSQL database used by analyticsInfra/Umami.",
      "tags": ["analytics", "postgresql", "infrastructure"]
    }
  },
  "volumes": {
    ".ploinky/data/analyticsDB/postgres": "/var/lib/postgresql/data"
  },
  "profiles": {
    "default": {
      "ports": ["127.0.0.1:15432:5432"],
      "env": {
        "POSTGRES_DB": {
          "required": false,
          "default": "umami"
        },
        "POSTGRES_USER": {
          "required": false,
          "default": "umami"
        },
        "POSTGRES_PASSWORD": {
          "name": "UMAMI_POSTGRES_PASSWORD",
          "required": true,
          "sharedGeneratedSecret": true
        }
      }
    }
  }
}
