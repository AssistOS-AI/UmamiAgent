{
  "container": "docker.umami.is/umami-software/umami:postgresql-latest",
  "entrypoint": "/bin/sh",
  "start": "/code/scripts/startUmami.sh",
  "readiness": {
    "protocol": "tcp"
  },
  "network": {
    "name": "analytics",
    "aliases": ["analytics-umami"]
  },
  "enable": ["analyticsDB"],
  "about": "Self-hosted Umami application for AchillesIDE analytics.",
  "endpoints": {
    "agent-card": {
      "name": "Analytics Infra",
      "description": "Runs the self-hosted Umami app used by analyticsAgent.",
      "tags": ["analytics", "umami", "infrastructure"]
    }
  },
  "profiles": {
    "default": {
      "ports": ["127.0.0.1:3000:3000"],
      "env": {
        "POSTGRES_DB": {
          "required": false,
          "default": "umami"
        },
        "POSTGRES_USER": {
          "required": false,
          "default": "umami"
        },
        "POSTGRES_PASSWORD": {
          "name": "UMAMI_POSTGRES_PASSWORD",
          "required": true,
          "sharedGeneratedSecret": true
        },
        "APP_SECRET": {
          "name": "UMAMI_APP_SECRET",
          "required": true,
          "sharedGeneratedSecret": true
        }
      }
    }
  }
}
