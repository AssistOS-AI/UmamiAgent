{
  "container": "docker.io/assistos/umami-agent:umami-stack",
  "lite-sandbox": true,
  "agent": "sh /code/scripts/start-umami-agent.sh",
  "readiness": {
    "protocol": "mcp"
  },
  "routerAccess": {
    "httpRoutes": [
      {
        "path": "/IDE-plugins/umami-settings/*",
        "access": "guest"
      }
    ]
  },
  "network": {
    "name": "umami",
    "aliases": ["umami-agent"]
  },
  "about": "Read-only Umami agent for AchillesIDE.",
  "endpoints": {
    "agent-card": {
      "name": "Umami Agent",
      "description": "Reads self-hosted Umami data through controlled MCP tools.",
      "tags": ["umami", "read-only"]
    }
  },
  "volumes": {
    ".ploinky/data/umamiAgent/postgres": "/var/lib/postgresql/data"
  },
  "profiles": {
    "default": {
      "additionalServerPort": "3000",
      "env": {
        "POSTGRES_DB": {
          "required": false,
          "default": "umami"
        },
        "POSTGRES_USER": {
          "required": false,
          "default": "umami"
        },
        "POSTGRES_PASSWORD": {
          "name": "UMAMI_POSTGRES_PASSWORD",
          "required": true,
          "sharedGeneratedSecret": true
        },
        "APP_SECRET": {
          "name": "UMAMI_APP_SECRET",
          "required": true,
          "sharedGeneratedSecret": true
        },
        "UMAMI_BASE_URL": {
          "required": false,
          "default": "http://127.0.0.1:3000"
        },
        "UMAMI_USERNAME": {
          "required": false,
          "default": "admin"
        },
        "UMAMI_PASSWORD": {
          "required": false,
          "default": "umami"
        },
        "UMAMI_TOKEN": {
          "required": false
        },
        "UMAMI_DEFAULT_WEBSITE_ID": {
          "required": false
        },
        "UMAMI_TIMEZONE": {
          "required": false
        },
        "UMAMI_MCP_PORT": {
          "required": false,
          "default": "7301"
        },
        "MCP_SECRET": {
          "name": "UMAMI_MCP_SECRET",
          "required": true,
          "sharedGeneratedSecret": true
        },
        "OAUTH_CLIENT_ID": {
          "required": false,
          "default": "umami-agent"
        },
        "OAUTH_REDIRECT_URI": {
          "required": false
        },
        "UMAMI_MCP_SQLITE_PATH": {
          "required": false,
          "default": "/tmp/umami-mcp/sessions.db"
        },
        "UMAMI_OUTPUT_DIR": {
          "required": false,
          "default": "/shared/deliverables/umami"
        }
      }
    }
  },
  "ideSettings": [
    {
      "key": "umami-settings",
      "label": "Umami Settings",
      "scope": "workspace",
      "pluginKey": "umamiAgent/umami-settings",
      "settingsComponent": "umami-settings",
      "adminOnly": false
    }
  ]
}
